# ──────────────────────────────────────────────────────────
# Attention Ledger — Environment Variables
# Copy this file to .env and fill in the values.
# ──────────────────────────────────────────────────────────

# ----- API (Python backend) --------------------------------

# URL of your local Ollama instance.
# When running inside Docker, use host.docker.internal to reach
# the host machine's Ollama process.
OLLAMA_URL=http://localhost:11434

# Ollama model to use for the agent (must be pulled already).
OLLAMA_MODEL=llama3

# Ollama sampling temperature (0.0 = deterministic, 1.0 = creative).
OLLAMA_TEMPERATURE=0.2

# Absolute path to the SQLite database file.
# Override when running outside Docker.
# ATTENTION_LEDGER_DB_PATH=/absolute/path/to/ledger.db

# Absolute path to the tasks directory containing *.yaml files.
# Override when running outside Docker.
# ATTENTION_LEDGER_TASKS_DIR=/absolute/path/to/tasks

# ----- Web (Next.js frontend) ------------------------------

# Base URL the browser uses to reach the API.
# Must be reachable from the user's browser, NOT from inside Docker.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# ----- Docker Compose overrides ----------------------------

# Set this when api and web containers need to talk to each other
# using container names instead of localhost.
# NEXT_PUBLIC_API_BASE_URL=http://api:8000
