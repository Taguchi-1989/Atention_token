# Attention Ledger — Environment Variables
# Copy this file to .env and edit as needed.

# ── Ollama (LLM) ──
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_TEMPERATURE=0.0

# ── Storage ──
# ATTENTION_LEDGER_DB_PATH=/app/data/ledger.db
# ATTENTION_LEDGER_TASKS_DIR=/app/python/tasks

# ── Dev mode ──
# Set to enable CORS for separate Next.js dev server (port 3000)
# ATTENTION_LEDGER_DEV=1

# ── API URL (only needed if frontend is deployed separately) ──
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
